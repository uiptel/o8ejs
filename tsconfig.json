{
  "compilerOptions": {
    "outDir": "dist/esm",
    "module": "esnext",
    "target": "es6",
    "lib": ["es6", "es2016", "es2017"],
    "declaration": true,
    "declarationDir": "dist/types",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}