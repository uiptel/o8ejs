{
  "name": "@uiptel/o8ejs",
  "version": "0.1.12",
  "description": "simple library for observable pattern design",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./src/typedefs.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./src/typedefs.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*.js",
    "!src/**/*.spec.js",
    "package.json"
  ],
  "scripts": {
    "test": "jest",
    "build": "rollup -c",
    "push": "npm publish --access public --verbose",
    "postpush": "sleep 3 && npm info @uiptel/o8ejs"
  },
  "keywords": [
    "observable",
    "subject",
    "reactive"
  ],
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@stylistic/eslint-plugin-js": "^2.11.0",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "rollup": "^4.27.4",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
